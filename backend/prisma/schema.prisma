// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ResourceType {
  room
  teacher
  course
}

enum UserRole {
  ADMIN
  TEACHER
  STUDENT
}

model User {
  id       String   @id @default(uuid())
  email    String   @unique
  password String
  role     UserRole @default(STUDENT)

  // 講師ユーザーの場合、対応するリソース
  resource Resource? @relation("UserResource")
}

model Resource {
  id    String       @id @default(uuid())
  name  String
  type  ResourceType
  order Int          @default(0)

  // 講師ユーザーとの紐付け
  userId String? @unique
  user   User?   @relation("UserResource", fields: [userId], references: [id])

  // 関連付け
  lessonsAsRoom    Lesson[] @relation("RoomLessons")
  lessonsAsTeacher Lesson[] @relation("TeacherLessons") // メイン講師
  lessonsAsSub     Lesson[] @relation("SubTeacherLessons") // サブ講師
  lessonsAsCourse  Lesson[] @relation("CourseLessons")

  // 個別の予定
  events ScheduleEvent[] @relation("ResourceEvents")
}

model Lesson {
  id            String   @id @default(uuid())
  subject       String
  startDate     String   // "2026-03-26"
  startPeriodId String   // "p1"
  endDate       String   // "2026-03-26"
  endPeriodId   String   // "p8"

  roomId    String
  teacherId String
  courseId  String

  room    Resource @relation("RoomLessons", fields: [roomId], references: [id])
  teacher Resource @relation("TeacherLessons", fields: [teacherId], references: [id])
  course  Resource @relation("CourseLessons", fields: [courseId], references: [id])

  // サブ講師
  subTeachers Resource[] @relation("SubTeacherLessons")
}

model ScheduleEvent {
  id            String   @id @default(uuid())
  name          String
  startDate     String
  startPeriodId String
  endDate       String
  endPeriodId   String
  color         String?
  showInEventRow Boolean @default(true)

  // 紐付け先リソース（講師、教室など）
  // 紐付けがない場合は全体のイベント（祝日、行事など）として扱う
  resources Resource[] @relation("ResourceEvents")
}

model Holiday {
  id    String  @id @default(uuid())
  name  String
  date  String? // "2026-01-01"
  start String? // "2026-12-29"
  end   String? // "2027-01-03"
}
